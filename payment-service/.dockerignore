# =========================================================================
# Payment Service (Node.js/Express) .dockerignore
# =========================================================================

# 1. Dependency Directories
# Exclude host-specific dependencies. Let npm/yarn handle this during the 
# container build phase to target the correct container OS and architecture.
node_modules/
jspm_packages/

# 2. Local File Uploads & Dynamic Storage
# Exclude any temporary or storage folders.
uploads/
storage/

# 3. Environment & Secrets
# Strictly exclude sensitive production keys, database passwords, and API credentials.
# We whitelist '.env.example' (if added in the future) for reference.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!.env.example

# 4. Version Control & Editor Configs
# Remove git history and IDE configurations from the build context.
.git
.gitignore
.gitattributes
.hg
.svn
.idea/
.vscode/
*.sw?

# 5. OS-Generated Files
# Exclude platform-specific system metadata.
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db

# 6. Logging & Debugging
# Prevent bloating the image layer with local runtime logs.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 7. Testing & Coverage
# Exclude test reports and coverage instrumentation data.
coverage/
.nyc_output/

# 8. Docker Files
# Avoid copying Docker instructions inside the image itself.
Dockerfile*
docker-compose*
.dockerignore
